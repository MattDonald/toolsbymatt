        <button class="preset-btn btn" data-preset="gameboy">gameboy</button>
        <button class="preset-btn btn" data-preset="soviet">soviet</button>
        <button class="preset-btn btn" data-preset="cassette">cassette</button>
        <button class="preset-btn btn" data-preset="transistor">transistor_radio</button>
        <button class="preset-btn btn" data-preset="fieldrecorder">field_recorder</button>
