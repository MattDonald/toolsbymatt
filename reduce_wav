</div>

<!-- PRE FILTER -->
<div class="section">
  <div class="row">
    <p class="row-label">Pre Filter</p>
    <button class="svg-toggle off" id="filterToggleBtn" aria-label="toggle pre filter">
      <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <g clip-path="url(#tc)">
          <!-- OFF state -->
          <rect x="0" y="0" width="100" height="50" rx="25" fill="#FC6F2F"/>
          <circle cx="28" cy="25" r="18" fill="#FFEBD2"/>
          <!-- ON state -->
          <rect y="50" width="100" height="50" rx="25" fill="#FC6F2F"/>
          <circle cx="73" cy="75" r="18" fill="#FFEBD2"/>
        </g>
        <defs><clipPath id="tc"><rect width="100" height="100"/></clipPath></defs>
      </svg>
    </button>
  </div>
  <div class="collapsible hidden" id="filterControls">
    <div class="row" style="margin-bottom:16px;">
      <div class="seg" id="filterModelSeg">
        <button class="btn active" data-val="butterworth">flat</button>
        <button class="btn" data-val="chebyshev">chebyshev_i</button>
