    <tbody id="fileTableBody"></tbody>
  </table>
</div>

<div style="text-align:center;margin-top:28px;">
  <button id="downloadBtn" disabled>reduce all</button>
</div>

<div class="notice" id="srNotice" style="display:none"><h3>sample rate reduction may take a moment on longer files</h3></div>
<div id="status"></div>


</div><!-- /controls -->
</div><!-- /reducer -->

<script>
// ── State ─────────────────────────────────────────────────────────────
let files = [];           // [{name, baseName, buffer, fileSize}] sorted alphabetically
let currentFileIdx = -1;  // which file is playing / queued
let audioCtx = null;
let previewSource = null;
let isPlaying = false;
let monoOutput = true;
let filterModel = 'butterworth';
let codec = 'linear';
let filterActive = false;
let ditherActive = true;
let bypass = false;
let starterOpen = false;
let activePreset = null;
let playbackGeneration = 0;
let processedBuf = null;
let originalBuf = null;
let playbackStart = 0;
let processedSR = null;

function getCtx(){
  if(!audioCtx) audioCtx = new (window.AudioContext||window.webkitAudioContext)();
  return audioCtx;
}

// ── Scale helpers ──────────────────────────────────────────────────────
const SR_MIN=Math.log(4000), SR_MAX=Math.log(48000);
function sliderToSR(v){return Math.round(Math.exp(SR_MIN+(v/1000)*(SR_MAX-SR_MIN)));}
function srToSlider(hz){return Math.round(((Math.log(hz)-SR_MIN)/(SR_MAX-SR_MIN))*1000);}
function srLabel(hz){return (hz/1000).toFixed(1)+' kHz';}

function fileSizeLabel(bytes){
  const kb=bytes/1024;
  return kb<1000?kb.toFixed(0)+' KB':(kb/1024).toFixed(1)+' MB';
}

function durLabel(secs){
  const m=Math.floor(secs/60),s=Math.floor(secs%60);
  return m>0?`${m}:${String(s).padStart(2,'0')}`:`${secs.toFixed(1)}s`;
}

const LP_MIN=Math.log(200), LP_MAX=Math.log(20000);
const HP_MIN=Math.log(20),  HP_MAX=Math.log(5000);
function sliderToLP(v){return v>=999?20001:Math.round(Math.exp(LP_MIN+(v/1000)*(LP_MAX-LP_MIN)));}
function lpToSlider(hz){return hz>20000?1000:Math.round(((Math.log(hz)-LP_MIN)/(LP_MAX-LP_MIN))*1000);}
function sliderToHP(v){return v<=1?0:Math.round(Math.exp(HP_MIN+(v/1000)*(HP_MAX-HP_MIN)));}
function hpToSlider(hz){return hz<=0?0:Math.round(((Math.log(hz)-HP_MIN)/(HP_MAX-HP_MIN))*1000);}
function fcLabel(hz,isHP){
  if(!isHP&&hz>20000)return 'off';
  if(isHP&&hz<=0)return 'off';
  return hz>=1000?(hz/1000).toFixed(1).replace(/\.0$/,'')+' kHz':hz+' Hz';
}

// ── Codec UI ───────────────────────────────────────────────────────────
const CODEC_HIDE_BD=['mulaw','adpcm','deltasigma'];
function applyCodecUI(){
  document.getElementById('rowBD').classList.toggle('hidden',CODEC_HIDE_BD.includes(codec));
}

// ── SVG Toggle helper ──────────────────────────────────────────────────
function setSvgToggle(btn,state){
  btn.classList.toggle('on',state);
  btn.classList.toggle('off',!state);
}

// ── Preset active state ────────────────────────────────────────────────
function clearPresetActive(){
  if(!activePreset)return;
  activePreset=null;
  document.querySelectorAll('.preset-btn').forEach(b=>b.classList.remove('active'));
}

// ── Seg controls ───────────────────────────────────────────────────────
function setupSeg(segId,onChange){
  document.getElementById(segId).querySelectorAll('.btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      document.getElementById(segId).querySelectorAll('.btn').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      onChange(btn.dataset.val);
    });
  });
}
setupSeg('filterModelSeg',val=>{filterModel=val;clearPresetActive();});
setupSeg('codecSeg',val=>{codec=val;applyCodecUI();clearPresetActive();updateTotalReduction();});

// ── Toggle handlers ────────────────────────────────────────────────────
document.getElementById('starterToggleBtn').addEventListener('click',()=>{
  starterOpen=!starterOpen;
  setSvgToggle(document.getElementById('starterToggleBtn'),starterOpen);
  document.getElementById('presetControls').classList.toggle('hidden',!starterOpen);
});
document.getElementById('filterToggleBtn').addEventListener('click',()=>{
  filterActive=!filterActive;
  setSvgToggle(document.getElementById('filterToggleBtn'),filterActive);
  document.getElementById('filterControls').classList.toggle('hidden',!filterActive);
  clearPresetActive();
});
document.getElementById('ditherBtn').addEventListener('click',()=>{
  ditherActive=!ditherActive;
  setSvgToggle(document.getElementById('ditherBtn'),ditherActive);
  clearPresetActive();
});

// ── Slider events ──────────────────────────────────────────────────────
document.getElementById('sampleRate').addEventListener('input',function(){
  document.getElementById('sampleRateVal').textContent=srLabel(sliderToSR(parseInt(this.value)));
  clearPresetActive();
  updateTotalReduction();
});
document.getElementById('bitDepth').addEventListener('input',function(){
  document.getElementById('bitDepthVal').textContent=parseInt(this.value)+'-bit';
  clearPresetActive();
  updateTotalReduction();
});
document.getElementById('filterLP').addEventListener('input',function(){
  document.getElementById('filterLPVal').textContent=fcLabel(sliderToLP(parseInt(this.value)),false);
  clearPresetActive();
});
document.getElementById('filterHP').addEventListener('input',function(){
  document.getElementById('filterHPVal').textContent=fcLabel(sliderToHP(parseInt(this.value)),true);
  clearPresetActive();
});
document.getElementById('filterRes').addEventListener('input',function(){
  document.getElementById('filterResVal').textContent=this.value;
  clearPresetActive();
});
document.getElementById('btnStereo').addEventListener('click',()=>{
  monoOutput=false;
  document.getElementById('btnStereo').classList.add('active');
  document.getElementById('btnMono').classList.remove('active');
  clearPresetActive();
  updateTotalReduction();
});
document.getElementById('btnMono').addEventListener('click',()=>{
  monoOutput=true;
  document.getElementById('btnMono').classList.add('active');
  document.getElementById('btnStereo').classList.remove('active');
  clearPresetActive();
  updateTotalReduction();
});

// ── File loading ───────────────────────────────────────────────────────
const dropZone=document.getElementById('dropZone');
const fileInput=document.getElementById('fileInput');
dropZone.addEventListener('click',()=>fileInput.click());
dropZone.addEventListener('dragover',e=>{e.preventDefault();dropZone.classList.add('active');});
dropZone.addEventListener('dragleave',()=>dropZone.classList.remove('active'));
dropZone.addEventListener('drop',e=>{
  e.preventDefault();dropZone.classList.remove('active');
  handleFiles(Array.from(e.dataTransfer.files));
});
fileInput.addEventListener('change',e=>handleFiles(Array.from(e.target.files)));

async function handleFiles(incoming){
  if(!incoming.length)return;
  stopPlayback();
  setStatus('loading…');
  const ctx=getCtx();

  const decoded=await Promise.all(incoming.map(async f=>{
    try{
      const ab=await f.arrayBuffer();
      const buffer=await ctx.decodeAudioData(ab);
      return {name:f.name, baseName:f.name.replace(/\.[^.]+$/,''), buffer, fileSize:f.size};
    }catch(e){
      setStatus(`could not decode "${f.name}"`);
      return null;
    }
  }));

  // Merge with existing, deduplicate by name, sort alphabetically
  const merged=[...files];
  for(const d of decoded){
    if(!d)continue;
    const existing=merged.findIndex(f=>f.name===d.name);
    if(existing>=0) merged[existing]=d; else merged.push(d);
  }
  merged.sort((a,b)=>a.name.localeCompare(b.name));
  files=merged;

  const label=document.getElementById('dropLabel');
  label.textContent='add more .wavs to reduce';
  label.classList.add('loaded');
  dropZone.classList.add('loaded');

  const totalBytes=files.reduce((a,f)=>a+f.fileSize,0);
  const fi=document.getElementById('fileInfo');
  fi.innerHTML=`<h2>${files.length} file${files.length===1?'':'s'} — ${fileSizeLabel(totalBytes)}</h2>`;
  fi.classList.remove('hidden');

  document.getElementById('controls').classList.remove('hidden');
  document.getElementById('previewBtn').disabled=false;
  document.getElementById('downloadBtn').disabled=false;
  document.getElementById('srNotice').style.display='none';

  renderTable();
  setStatus('');
  updateTotalReduction();
}

// ── File table ─────────────────────────────────────────────────────────
function renderTable(){
  const tbody=document.getElementById('fileTableBody');
  const wrap=document.getElementById('fileTable-wrap');
  tbody.innerHTML='';
  files.forEach((f,i)=>{
    const ch=f.buffer.numberOfChannels;
    const tr=document.createElement('tr');
    tr.dataset.idx=i;
