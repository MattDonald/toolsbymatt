</div>

<div class="actions">
  <button id="previewBtn" disabled><span class="preview-icon"><svg viewBox="0 0 80 160" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M28.2274 103.552C25.657 103.552 23.5518 105.657 23.5518 108.227V131.769C23.5518 134.339 25.657 136.444 28.2274 136.444H51.7688C54.3426 136.444 56.4445 134.339 56.4445 131.769V108.227C56.4445 105.657 54.3392 103.552 51.7688 103.552H28.2274Z"/><path d="M54.0392 42.1406L34.1602 54.2886C32.6094 55.2378 30.6602 54.0503 30.6602 52.148V27.847C30.6602 25.9486 32.6094 24.7572 34.1602 25.7064L54.0392 37.8544C55.5978 38.8036 55.5978 41.1825 54.0392 42.1356V42.1406Z"/></svg></span><span class="preview-label">preview</span></button>
</div>
<h2 id="totalReduction" style="display:none;margin-top:20px;"></h2>

<div id="fileTable-wrap" class="hidden">
