<style>
  #reducer { text-transform: lowercase; }
  #reducer .drop-zone { border: 2px dashed #FC6F2F; padding: 70px; text-align: center; cursor: pointer; }
  #reducer .drop-zone.loaded { padding: 12px 20px; }
  #reducer .fileInfo, #reducer #controls { width: 100%; max-width: 472px; margin: 0 auto; }
  #reducer .reducedInfo .arrow { color: #FC6F2F; margin: 0 4px; }
  #reducer .row { display: flex; align-items: center; gap: 14px; margin: 20px 0; }
  #reducer .slider-wrap { position: relative; flex: 1; height: 26px; display: flex; align-items: center; }
  #reducer input[type=range] { -webkit-appearance: none; appearance: none; width: 100%; height: 4px; background: #FC6F2F; outline: none; cursor: pointer; position: relative; z-index: 2; }
  #reducer input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 25px; height: 25px; border-radius: 50%; background: #fc6f2f; cursor: pointer; border: 5px solid #FFEBD2; }
  #reducer input[type=range]::-webkit-slider-thumb:active { transform: scale(1.2); }
  #reducer input[type=range]::-moz-range-thumb { width: 25px; height: 25px; border-radius: 50%; background: #fc6f2f; cursor: pointer; border: 5px solid #FFEBD2; }
  #reducer .seg { display: flex; flex-wrap: wrap; gap: 6px; }
  #reducer .ch-toggle { display: flex; width: fit-content; }
  #reducer .ch-btn { background: #FFEBD2; color: #FC6F2F; border: 1px solid #FC6F2F; padding: 9px 28px 12px 28px; font-family: custom_175773; font-weight: 500; font-size: 18px; cursor: pointer; line-height: 1; }
  #reducer .ch-btn.active { background: #FC6F2F; color: #FFEBD2; border: 1px solid #FC6F2F; padding: 9px 28px 12px 28px; font-family: custom_175773; font-weight: 500; font-size: 18px; cursor: pointer; line-height: 1; }
  #reducer .ch-btn:first-child { border-radius: 100px 0 0 100px; }
  #reducer .ch-btn:last-child { border-radius: 0 100px 100px 0; }
  #reducer .btn, #reducer #previewBtn:hover,  #reducer #downloadBtn:hover { background: #FFEBD2; color: #FC6F2F; border: 1px solid #FC6F2F; border-radius: 100px; padding: 9px 28px 12px 28px; font-family: custom_175773; font-weight: 500; font-size: 18px; cursor: pointer; line-height: 1; }
  #reducer .btn.active, #reducer #previewBtn, #reducer #downloadBtn { background: #FC6F2F; color: #FFEBD2; border: 1px solid #FC6F2F; border-radius: 100px; padding: 9px 28px 12px 28px; font-family: custom_175773; font-weight: 500; font-size: 18px; cursor: pointer; line-height: 1; }
  #reducer #previewBtn { display: inline-flex; align-items: center; gap: 10px; }
  #reducer #previewBtn .preview-icon { width: 20px; height: 20px; overflow: hidden; position: relative; flex-shrink: 0; }
  #reducer #previewBtn .preview-icon svg { width: 20px; height: 40px; position: absolute; top: 0; left: 0; }
  #reducer #previewBtn .preview-icon svg path { fill: #FFEBD2; }
  #reducer #previewBtn:hover .preview-icon svg path { fill: #FC6F2F; }
  #reducer #previewBtn.playing .preview-icon svg { top: -20px; }
  #reducer .btn:disabled, #reducer .svg-toggle:disabled, #reducer input[type=range]:disabled, .ch-btn:disabled { opacity: 0.3; cursor: not-allowed; }
  #reducer .collapsible { margin-top: 14px; }
  #reducer .svg-toggle { width: 41px; height: 20px; background: none; border: none; padding: 0; cursor: pointer; overflow: hidden; flex-shrink: 0; display: block; position: relative; }
  #reducer .svg-toggle svg { width: 40px; height: 40px; position: absolute; top: 0; left: 0; }
  #reducer .svg-toggle.off svg { top: 0; }
  #reducer .svg-toggle.on svg { top: -20px; }
  #reducer #previewBtn { display: inline-flex; align-items: center; gap: 10px; }
  #reducer h2 { color: rgba(252, 111, 47, 1); font-family: custom_175773; font-style: normal; text-align: left; font-size: 50px; font-weight: 500; line-height: 50px; margin: 40px 0; }
  #reducer #fileInfo h2, #reducer .drop-zone h2 { text-align: center; }
  #reducer h2.loaded { font-size: 18px; margin: 0; line-height: 25px; }
  #reducer h3 { font-family: JetBrains Mono; font-weight: 400; font-size: 20px; line-height: 30px; font-style: italic; color: rgba(252, 111, 47, 1); text-align: left; font-variation-settings: 'wght' 600; margin: 20px 0 0 0; }
  #reducer .row-label { width: 80px; flex-shrink: 0; text-align: right; }
  #reducer p, #reducer .fileInfo, #reducer .reducedInfo, #reducer .val { color: rgba(252, 111, 47, 1); font-family: JetBrains Mono; font-style: italic; text-align: left; font-size: 12px; font-weight: 400; line-height: 20px; font-variation-settings: 'wght' 600; }
  #reducer .val { width: 60px; text-align: right; flex-shrink: 0; }
  #reducer .notice { margin: 40px 0; }
  #reducer .hidden { display: none !important; }
  @media screen and (max-width: 320px) { #reducer #reducedInfo { display: block; } }
  #reducer #fileTable { width: 100%; max-width: 472px; margin: 28px auto 0 auto; border-collapse: collapse; }
  #reducer #fileTable-wrap { width: 100%; max-width: 472px; margin: 28px auto 0 auto; max-height: calc(5 * 37px); overflow-y: auto; }
  #reducer #fileTable { width: 100%; margin: 0; border-collapse: collapse; }
  #reducer #fileTable td { padding: 6px 8px; vertical-align: middle; color: rgba(252,111,47,1); font-family: JetBrains Mono; font-style: italic; font-size: 12px; font-variation-settings: 'wght' 600; border-bottom: 1px solid rgba(252,111,47,0.15); }
  #reducer #fileTable tr.playing td { background: rgba(252, 111, 47, 1); color: #FFEBD2; }
  #reducer #fileTable .row-play-btn { background: none; border: none; padding: 0; cursor: pointer; width: 28px; height: 28px; overflow: hidden; position: relative; flex-shrink: 0; }
  #reducer #fileTable .row-play-btn svg { width: 28px; height: 56px; position: absolute; top: 0; left: 0; }
  #reducer #fileTable .row-play-btn.playing svg { top: -28px; }
  #reducer #fileTable .row-play-btn:disabled { opacity: 0.3; cursor: not-allowed; }
  #reducer #fileTable .col-name { word-break: break-all; }
  #reducer #fileTable .col-ch, #reducer #fileTable .col-dur { white-space: nowrap; text-align: right; }
</style>

<div id="reducer">

<!-- FILE DROP -->
<div class="drop-zone" id="dropZone">
  <h2 id="dropLabel">add .wav files to reduce</h2>
  <input type="file" id="fileInput" accept=".wav,.aif,.aiff,audio/*" multiple style="display:none">
</div>

<!-- FILE INFO -->
<div id="fileInfo" class="hidden"></div>

<!-- CONTROLS -->
<div id="controls" class="hidden">

<!-- PRESETS -->
<div class="section">
