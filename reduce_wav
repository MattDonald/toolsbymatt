// ── Playback helpers ───────────────────────────────────────────────────
function upsampleForPlayback(channels, fromSR){
  const ctx=getCtx();
  const toSR=ctx.sampleRate;
  if(Math.abs(fromSR-toSR)<1) return channels;
  const ratio=fromSR/toSR;
  return channels.map(ch=>resampleNearest(ch, ratio));
}

function makeAudioBufferNative(channels, sr){
  const ctx=getCtx();
  const upsampled=upsampleForPlayback(channels, sr);
  const nativeSR=ctx.sampleRate;
  const buf=ctx.createBuffer(upsampled.length, upsampled[0].length, nativeSR);
  for(let c=0;c<upsampled.length;c++) buf.copyToChannel(upsampled[c],c);
  return buf;
}

// ── Playback ───────────────────────────────────────────────────────────
let playQueued = false; // true = advance to next file on end; false = stop after this file

function playFile(idx){
  if(idx<0||idx>=files.length)return;
  const f=files[idx];
  currentFileIdx=idx;
  const btn=document.getElementById('previewBtn');
  setPreviewBtn(btn,'processing\u2026',false);btn.disabled=true;
  setTimeout(async()=>{
    try{
      const ctx=getCtx();
      if(ctx.state==='suspended') await ctx.resume();
      const settings=getSettings();
      const result=processBuffer(f.buffer,settings);
      processedBuf=makeAudioBufferNative(result.channels,result.sr);
      originalBuf=makeAudioBufferNative(getChannelsFrom(f.buffer),f.buffer.sampleRate);
      processedSR=result.sr;
      isPlaying=true;
      setPreviewBtn(btn,'stop',true);btn.disabled=false;
      setControlsDisabled(true);
      document.getElementById('bypassBtn').disabled=false;
      setRowPlaying(idx);
      startSource(bypass?originalBuf:processedBuf,0,bypass?null:processedSR);
    }catch(e){
      setPreviewBtn(btn,'preview',false);btn.disabled=false;
      document.getElementById('downloadBtn').disabled=false;
      setControlsDisabled(false);
      setStatus('error: '+e.message);
    }
  },10);
}

// Updates preview button state without clobbering the SVG icon span
function setPreviewBtn(btn, label, playing){
  btn.classList.toggle('playing', playing);
  const lbl=btn.querySelector('.preview-label');
  if(lbl) lbl.textContent=label;
}

function startSource(buf, offset, targetSR){
  const ctx=getCtx();
  const gen=++playbackGeneration;
  if(previewSource){try{previewSource.stop();}catch(e){}previewSource=null;}
  const src=ctx.createBufferSource();
  src.buffer=buf;

  if(targetSR && targetSR < ctx.sampleRate){
    const cutoff=targetSR * 0.45;
    const filters=[...Array(5)].map(()=>{
        const f=ctx.createBiquadFilter();
        f.type='lowpass';f.frequency.value=cutoff;f.Q.value=0.707;
        return f;
    });
    filters.reduce((a,b)=>{a.connect(b);return b;});
    src.connect(filters[0]);
    filters[filters.length-1].connect(ctx.destination);
} else {
    src.connect(ctx.destination);
  }

  src.start(0, offset);
  playbackStart=ctx.currentTime-offset;
  previewSource=src;
  src.onended=()=>{
    if(gen!==playbackGeneration)return;
    if(isPlaying){
      if(playQueued && currentFileIdx+1<files.length){
        playFile(currentFileIdx+1);
      } else {
        isPlaying=false;previewSource=null;currentFileIdx=-1;playQueued=false;
        clearRowPlaying();
        const b=document.getElementById('previewBtn');
        setPreviewBtn(b,'preview',false);
        setControlsDisabled(false);
        document.getElementById('downloadBtn').disabled=!files.length;
      }
    }
  };
}

function stopPlayback(){
  playbackGeneration++;
  if(previewSource){try{previewSource.stop();}catch(e){}previewSource=null;}
  isPlaying=false;processedBuf=null;originalBuf=null;processedSR=null;playQueued=false;
  currentFileIdx=-1;
  clearRowPlaying();
  const btn=document.getElementById('previewBtn');
  setPreviewBtn(btn,'preview',false);
  btn.disabled=!files.length;
  setControlsDisabled(false);
  document.getElementById('downloadBtn').disabled=!files.length;
}

// Main preview button — plays full queue from start
document.getElementById('previewBtn').addEventListener('click',()=>{
  if(isPlaying){stopPlayback();return;}
  if(!files.length)return;
  playQueued=true;
  playFile(0);
});

document.getElementById('bypassBtn').addEventListener('click',()=>{
  bypass=!bypass;
  setSvgToggle(document.getElementById('bypassBtn'),bypass);
  if(isPlaying&&processedBuf&&originalBuf){
    const ctx=getCtx();
    const elapsed=ctx.currentTime-playbackStart;
    const targetBuf=bypass?originalBuf:processedBuf;
    startSource(targetBuf,Math.min(Math.max(0,elapsed),targetBuf.duration-0.01),bypass?null:processedSR);
  }
});

// ── Download — zip all files ────────────────────────────────────────────
function encodeWav(channels,sr,bits){
  const numCh=channels.length,numFrames=channels[0].length,bps=bits/8;
  const dataSize=numFrames*numCh*bps,ab=new ArrayBuffer(44+dataSize),v=new DataView(ab);
  const ws=(o,s)=>{for(let i=0;i<s.length;i++)v.setUint8(o+i,s.charCodeAt(i));};
  ws(0,'RIFF');v.setUint32(4,36+dataSize,true);ws(8,'WAVE');ws(12,'fmt ');
  v.setUint32(16,16,true);v.setUint16(20,1,true);v.setUint16(22,numCh,true);
  v.setUint32(24,sr,true);v.setUint32(28,sr*numCh*bps,true);
  v.setUint16(32,numCh*bps,true);v.setUint16(34,bits,true);
  ws(36,'data');v.setUint32(40,dataSize,true);
  let offset=44;
  for(let i=0;i<numFrames;i++){
    for(let c=0;c<numCh;c++){
      const s=Math.max(-1,Math.min(1,channels[c][i]));
      if(bits===32){v.setInt32(offset,Math.round(s*2147483647),true);offset+=4;}
      else if(bits===24){const val=Math.round(s*8388607);v.setUint8(offset,val&0xff);v.setUint8(offset+1,(val>>8)&0xff);v.setUint8(offset+2,(val>>16)&0xff);offset+=3;}
      else if(bits===8){v.setUint8(offset,Math.round((s+1)*127.5));offset+=1;}
      else{v.setInt16(offset,Math.round(s*32767),true);offset+=2;}
    }
  }
  return new Blob([ab],{type:'audio/wav'});
}

// ── Minimal ZIP encoder (STORED, no compression) ──────────────────────────────
function buildZip(entries){
  const enc=new TextEncoder();
  const parts=[],centralDir=[];
  let offset=0;
  function crc32(data){
    let c=0xFFFFFFFF;
    for(let i=0;i<data.length;i++){
      c^=data[i];
      for(let j=0;j<8;j++)c=c&1?(c>>>1)^0xEDB88320:(c>>>1);
    }
    return(c^0xFFFFFFFF)>>>0;
  }
  for(const{name,data}of entries){
    const nb=enc.encode(name),crc=crc32(data),sz=data.length;
    const lf=new Uint8Array(30+nb.length),ld=new DataView(lf.buffer);
    ld.setUint32(0,0x04034b50,true);ld.setUint16(4,20,true);ld.setUint16(6,0,true);
    ld.setUint16(8,0,true);ld.setUint16(10,0,true);ld.setUint16(12,0,true);
    ld.setUint32(14,crc,true);ld.setUint32(18,sz,true);ld.setUint32(22,sz,true);
    ld.setUint16(26,nb.length,true);ld.setUint16(28,0,true);lf.set(nb,30);
    const cd=new Uint8Array(46+nb.length),dd=new DataView(cd.buffer);
    dd.setUint32(0,0x02014b50,true);dd.setUint16(4,20,true);dd.setUint16(6,20,true);
    dd.setUint16(8,0,true);dd.setUint16(10,0,true);dd.setUint16(12,0,true);dd.setUint16(14,0,true);
    dd.setUint32(16,crc,true);dd.setUint32(20,sz,true);dd.setUint32(24,sz,true);
    dd.setUint16(28,nb.length,true);dd.setUint16(30,0,true);dd.setUint16(32,0,true);
    dd.setUint16(34,0,true);dd.setUint16(36,0,true);dd.setUint32(38,0,true);
    dd.setUint32(42,offset,true);cd.set(nb,46);
    parts.push(lf,data);centralDir.push(cd);offset+=lf.length+data.length;
  }
  const cdsz=centralDir.reduce((a,b)=>a+b.length,0);
  const eocd=new Uint8Array(22),ev=new DataView(eocd.buffer);
  ev.setUint32(0,0x06054b50,true);ev.setUint16(4,0,true);ev.setUint16(6,0,true);
  ev.setUint16(8,entries.length,true);ev.setUint16(10,entries.length,true);
  ev.setUint32(12,cdsz,true);ev.setUint32(16,offset,true);ev.setUint16(20,0,true);
  const all=[...parts,...centralDir,eocd];
  const total=all.reduce((a,b)=>a+b.length,0);
  const out=new Uint8Array(total);let pos=0;
  for(const p of all){out.set(p,pos);pos+=p.length;}
  return new Blob([out],{type:'application/zip'});
}

document.getElementById('downloadBtn').addEventListener('click',async()=>{
  if(!files.length)return;
  stopPlayback();
  document.getElementById('downloadBtn').disabled=true;
  document.getElementById('previewBtn').disabled=true;
  setStatus('processing…');
  try{
    const settings=getSettings();
    const entries=[];
    for(const f of files){
      const result=processBuffer(f.buffer,settings);
      const outBits=CODEC_HIDE_BD.includes(settings.codec)?16:settings.bits;
      const blob=encodeWav(result.channels,result.sr,outBits);
      const ab=await blob.arrayBuffer();
      const srL=(result.sr/1000).toFixed(1);
      const monoL=result.channels.length===1?'_mono':'';
      entries.push({name:`${f.baseName}_${srL}k_${settings.codec}${monoL}.wav`,data:new Uint8Array(ab)});
    }
    const zipBlob=buildZip(entries);
    const url=URL.createObjectURL(zipBlob);
    const a=document.createElement('a');
    a.download=`reduced_${files.length}file${files.length===1?'':'s'}.zip`;
    a.href=url;a.click();URL.revokeObjectURL(url);
    setStatus('');
  }catch(e){
    setStatus('export error: '+e.message);
  }
  document.getElementById('downloadBtn').disabled=false;
  document.getElementById('previewBtn').disabled=false;
});

function setStatus(msg){
  const el=document.getElementById('status');
  el.innerHTML=msg?`<h3>${msg}</h3>`:'';
}

function updateTotalReduction(){
  const el=document.getElementById('totalReduction');
  if(!files.length){el.style.display='none';return;}
  const s=getSettings();
  const outBits=CODEC_HIDE_BD.includes(s.codec)?16:s.bits;
  const outCh=monoOutput?1:null; // null means per-file channel count
  let origTotal=0,outTotal=0;
  for(const f of files){
    origTotal+=f.fileSize;
    const fCh=outCh!==null?outCh:f.buffer.numberOfChannels;
    const ratio=f.buffer.sampleRate/s.targetSR;
    const outFrames=Math.floor(f.buffer.length/ratio);
    outTotal+=44+outFrames*fCh*(outBits/8);
  }
  const rawPct=100-(outTotal/origTotal*100);
  const pctStr=rawPct>0.5?`\u2212${rawPct.toFixed(0)}%`:rawPct<-0.5?`+${Math.abs(rawPct).toFixed(0)}%`:'\u22480%';
  el.textContent=pctStr;
  el.style.display='block';
}

// ── Presets ────────────────────────────────────────────────────────────
const PRESETS={
  telephone: {sr:8000, bits:16,lp:3400, hp:300,res:20,filterModel:'chebyshev',codec:'mulaw',     mono:true},
  gameboy:   {sr:11025,bits:16,lp:20001,hp:0,  res:0, filterModel:'butterworth',codec:'nearest',  mono:true},
  soviet:    {sr:11025,bits:16,lp:8000, hp:80, res:40,filterModel:'moog',       codec:'adpcm',    mono:true},
  cassette:  {sr:22050,bits:16,lp:14000,hp:60, res:10,filterModel:'butterworth',codec:'linear',   mono:false},
  transistor:{sr:11025,bits:16,lp:6000, hp:500,res:30,filterModel:'chebyshev',  codec:'mulaw',    mono:true},
  fieldrecorder:{sr:22050,bits:16,lp:20001,hp:40,res:0,filterModel:'butterworth',codec:'polyphase',mono:true},
  destroyed: {sr:4000, bits:16,lp:20001,hp:0,  res:0, filterModel:'butterworth',codec:'deltasigma',mono:true},
};

function applyPreset(name){
  const p=PRESETS[name];if(!p)return;
  activePreset=name;
  document.querySelectorAll('.preset-btn').forEach(b=>b.classList.toggle('active',b.dataset.preset===name));
  document.getElementById('sampleRate').value=srToSlider(p.sr);
  document.getElementById('sampleRateVal').textContent=srLabel(p.sr);
  document.getElementById('bitDepth').value=p.bits;
  document.getElementById('bitDepthVal').textContent=p.bits+'-bit';
  document.getElementById('filterLP').value=p.lp>20000?1000:lpToSlider(p.lp);
  document.getElementById('filterLPVal').textContent=fcLabel(p.lp,false);
  document.getElementById('filterHP').value=p.hp<=0?0:hpToSlider(p.hp);
  document.getElementById('filterHPVal').textContent=fcLabel(p.hp,true);
  document.getElementById('filterRes').value=p.res;
  document.getElementById('filterResVal').textContent=p.res;
  filterModel=p.filterModel;
  document.querySelectorAll('#filterModelSeg .btn').forEach(b=>b.classList.toggle('active',b.dataset.val===p.filterModel));
  codec=p.codec;
  document.querySelectorAll('#codecSeg .btn').forEach(b=>b.classList.toggle('active',b.dataset.val===p.codec));
  applyCodecUI();
  monoOutput=p.mono;
  document.getElementById('btnMono').classList.toggle('active',p.mono);
  document.getElementById('btnStereo').classList.toggle('active',!p.mono);
  filterActive=(p.lp<20001||p.hp>0);
  setSvgToggle(document.getElementById('filterToggleBtn'),filterActive);
  document.getElementById('filterControls').classList.toggle('hidden',!filterActive);
  ditherActive=true;
  setSvgToggle(document.getElementById('ditherBtn'),true);
  updateTotalReduction();
}

document.querySelectorAll('.preset-btn').forEach(btn=>{
  btn.addEventListener('click',()=>applyPreset(btn.dataset.preset));
});

applyCodecUI();
</script>
