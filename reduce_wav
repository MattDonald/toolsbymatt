// ── DSP: Filters ───────────────────────────────────────────────────────
function runBiquad(s,b0,b1,b2,a1,a2){
  const out=new Float32Array(s.length);let z1=0,z2=0;
  for(let i=0;i<s.length;i++){const x=s[i],y=b0*x+z1;z1=b1*x-a1*y+z2;z2=b2*x-a2*y;out[i]=y;}
  return out;
}
function butterworth(s,type,cutoffHz,sr,Q){
  const f=Math.min(cutoffHz/sr,0.499),K=Math.tan(Math.PI*f),norm=1/(1+K/Q+K*K);
  let b0,b1,b2;
  if(type==='lp'){b0=K*K*norm;b1=2*b0;b2=b0;}else{b0=norm;b1=-2*norm;b2=norm;}
  return runBiquad(s,b0,b1,b2,2*(K*K-1)*norm,(1-K/Q+K*K)*norm);
}
function chebyshev1(s,type,cutoffHz,sr,Q){
  const eps=Math.sqrt(Math.pow(10,0.05)-1);
  const f=Math.min(cutoffHz/sr,0.499),K=Math.tan(Math.PI*f)/Math.sqrt(eps);
  const norm=1/(1+K/Q+K*K);
  let b0,b1,b2;
  if(type==='lp'){b0=K*K*norm;b1=2*b0;b2=b0;}else{b0=norm;b1=-2*norm;b2=norm;}
  return runBiquad(s,b0,b1,b2,2*(K*K-1)*norm,(1-K/Q+K*K)*norm);
}
function moogLadder(s,type,cutoffHz,sr,Q){
  const f=Math.min(cutoffHz/sr,0.499),fc=f*1.16,res=Math.min(Q*0.1,0.95);
  let x=[0,0,0,0],y=[0,0,0,0];
  const out=new Float32Array(s.length);
  for(let i=0;i<s.length;i++){
    const inp=s[i]-res*y[3];x[0]=inp;
    y[0]+=(Math.tanh(x[0]*1.8)-Math.tanh(y[0]*1.8))*fc;
    for(let k=1;k<4;k++)y[k]+=(Math.tanh(y[k-1]*1.8)-Math.tanh(y[k]*1.8))*fc;
    out[i]=type==='lp'?y[3]:s[i]-y[3];
  }
  return out;
}
function applyFilter(s,type,cutoffHz,sr,Q,model){
  if(type==='lp'&&cutoffHz>sr/2)return s;
  if(type==='hp'&&cutoffHz<=0)return s;
  const safeQ=Math.max(0.5,Q);
  if(model==='chebyshev')return chebyshev1(s,type,cutoffHz,sr,safeQ);
  if(model==='moog')return moogLadder(s,type,cutoffHz,sr,safeQ);
  return butterworth(s,type,cutoffHz,sr,safeQ);
}

// ── DSP: Resamplers & Codecs ───────────────────────────────────────────
function buildSincKernel(cutoff,taps){
  const h=new Float32Array(taps),half=(taps-1)/2;let sum=0;
  for(let i=0;i<taps;i++){
    const x=i-half;
    h[i]=x===0?2*cutoff:Math.sin(2*Math.PI*cutoff*x)/(Math.PI*x);
    h[i]*=0.5*(1-Math.cos(2*Math.PI*i/(taps-1)));sum+=h[i];
  }
  for(let i=0;i<taps;i++)h[i]/=sum;return h;
}
function applyFIR(s,k){
  const t=k.length,h=Math.floor(t/2),out=new Float32Array(s.length);
  for(let i=0;i<s.length;i++){
    let a=0;for(let j=0;j<t;j++){const idx=i+j-h;if(idx>=0&&idx<s.length)a+=s[idx]*k[j];}
    out[i]=a;
  }
  return out;
}
function resampleNearest(s,ratio){
  const n=Math.max(1,Math.floor(s.length/ratio)),out=new Float32Array(n);
  for(let i=0;i<n;i++)out[i]=s[Math.min(Math.round(i*ratio),s.length-1)];
  return out;
}
function resampleLinear(s,ratio){
  const n=Math.max(1,Math.floor(s.length/ratio)),out=new Float32Array(n);
  for(let i=0;i<n;i++){
    const p=i*ratio,lo=Math.floor(p),hi=Math.min(lo+1,s.length-1);
    out[i]=s[lo]*(1-(p-lo))+s[hi]*(p-lo);
  }
  return out;
}
function resamplePolyphase(s,inputSR,targetSR){
  const ratio=inputSR/targetSR;
  if(Math.abs(ratio-1)<0.001)return Float32Array.from(s);
  if(ratio<1)return resampleLinear(s,ratio);
  const cutoff=0.5/ratio,numTaps=Math.min(255,Math.floor(ratio)*32+1);
  const taps=numTaps%2===0?numTaps+1:numTaps;
  return resampleLinear(applyFIR(s,buildSincKernel(cutoff,taps)),ratio);
}
function applyMulaw(s,inputSR,targetSR){
  const mu=255,enc=new Float32Array(s.length);
  for(let i=0;i<s.length;i++){
    const sign=s[i]<0?-1:1,v=Math.abs(Math.max(-1,Math.min(1,s[i])));
    enc[i]=sign*Math.log(1+mu*v)/Math.log(1+mu);
  }
  const q=new Float32Array(s.length);
  for(let i=0;i<s.length;i++)q[i]=Math.round(enc[i]*127)/127;
  const down=resampleLinear(q,inputSR/targetSR),out=new Float32Array(down.length);
  for(let i=0;i<down.length;i++){
    const sign=down[i]<0?-1:1,v=Math.abs(down[i]);
    out[i]=sign*(Math.pow(1+mu,v)-1)/mu;
  }
  return out;
}
function applyADPCM(s,inputSR,targetSR){
  const stepTable=[7,8,9,10,11,12,13,14,16,17,19,21,23,25,28,31,34,37,41,45,50,55,60,66,73,80,88,97,107,118,130,143,157,173,190,209,230,253,279,307,337,371,408,449,494,544,598,658,724,796,876,963,1060,1166,1282,1411,1552];
  const indexTable=[-1,-1,-1,-1,2,4,6,8,-1,-1,-1,-1,2,4,6,8];
  let stepIdx=0,predicted=0;
  const encoded=new Int8Array(s.length);
  for(let i=0;i<s.length;i++){
    const step=stepTable[stepIdx];let diff=Math.round(s[i]*32767)-predicted;
    let nibble=0;if(diff<0){nibble=8;diff=-diff;}
    if(diff>=step){nibble|=4;diff-=step;}if(diff>=step/2){nibble|=2;diff-=step/2;}if(diff>=step/4){nibble|=1;}
    encoded[i]=nibble;
    let delta=step>>3;
    if(nibble&4)delta+=step;if(nibble&2)delta+=step>>1;if(nibble&1)delta+=step>>2;if(nibble&8)delta=-delta;
    predicted=Math.max(-32768,Math.min(32767,predicted+delta));
    stepIdx=Math.max(0,Math.min(56,stepIdx+indexTable[nibble&7]));
  }
  stepIdx=0;predicted=0;
  const decoded=new Float32Array(s.length);
  for(let i=0;i<s.length;i++){
    const nibble=encoded[i],step=stepTable[stepIdx];
    let delta=step>>3;
    if(nibble&4)delta+=step;if(nibble&2)delta+=step>>1;if(nibble&1)delta+=step>>2;if(nibble&8)delta=-delta;
    predicted=Math.max(-32768,Math.min(32767,predicted+delta));
    decoded[i]=predicted/32768;
    stepIdx=Math.max(0,Math.min(56,stepIdx+indexTable[nibble&7]));
  }
  return resampleLinear(decoded,inputSR/targetSR);
}
function applyDeltaSigma(s,inputSR,targetSR){
  const oversampling=Math.max(1,Math.round(inputSR/targetSR));
  let integrator1=0,integrator2=0;
  const bitstream=new Int8Array(s.length);
  for(let i=0;i<s.length;i++){
    const x=Math.max(-0.99,Math.min(0.99,s[i]));
    const q=integrator2>=0?1:-1;bitstream[i]=q;
    const err=x-q;integrator2=integrator1+err*0.5;integrator1+=err;
  }
  const outLen=Math.max(1,Math.floor(s.length/oversampling)),out=new Float32Array(outLen);
  for(let i=0;i<outLen;i++){
    let sum=0,count=0;
    for(let j=0;j<oversampling;j++){const idx=i*oversampling+j;if(idx<bitstream.length){sum+=bitstream[idx];count++;}}
    out[i]=count>0?sum/count:0;
  }
  return out;
}
function quantise(s,bits,dither){
  if(bits>=32)return s;
  const scale=Math.pow(2,bits-1);
  const out=new Float32Array(s.length);
  for(let i=0;i<s.length;i++){
    let v=s[i];
    if(dither) v+=(Math.random()+Math.random()-1)/scale;
    out[i]=Math.max(-1,Math.min(1,Math.round(v*scale)/scale));
  }
  return out;
}

// ── Main process — operates on a given AudioBuffer ────────────────────
function getChannelsFrom(buffer){
  const numCh=buffer.numberOfChannels;
  if(monoOutput&&numCh>1){
    const len=buffer.length,mono=new Float32Array(len);
    for(let c=0;c<numCh;c++){const ch=buffer.getChannelData(c);for(let i=0;i<len;i++)mono[i]+=ch[i];}
    for(let i=0;i<mono.length;i++)mono[i]/=numCh;
    return [mono];
  }
  const out=[];
  for(let c=0;c<numCh;c++)out.push(Float32Array.from(buffer.getChannelData(c)));
  return out;
}

function processBuffer(buffer,settings){
  const {targetSR,bits,useDither,lpCutoff,hpCutoff,filterRes,codec,filterActive}=settings;
  const inputSR=buffer.sampleRate;
  const Q=0.707+(filterRes/100)*9;
  const model=settings.filterModel;
  const channels=getChannelsFrom(buffer);
  const processed=[];
  for(const raw of channels){
    let s=Float32Array.from(raw);
    if(filterActive){
      if(lpCutoff<=inputSR/2) s=applyFilter(s,'lp',lpCutoff,inputSR,Q,model);
      if(hpCutoff>0&&hpCutoff<inputSR/2) s=applyFilter(s,'hp',hpCutoff,inputSR,Q,'butterworth');
    }
    switch(codec){
      case 'nearest':    s=resampleNearest(s,inputSR/targetSR); break;
      case 'polyphase':  s=resamplePolyphase(s,inputSR,targetSR); break;
      case 'mulaw':      s=applyMulaw(s,inputSR,targetSR); break;
      case 'adpcm':      s=applyADPCM(s,inputSR,targetSR); break;
      case 'deltasigma': s=applyDeltaSigma(s,inputSR,targetSR); break;
      default:           s=resampleLinear(s,inputSR/targetSR); break;
    }
    if(!CODEC_HIDE_BD.includes(codec)) s=quantise(s,bits,useDither);
    processed.push(s);
  }
  const outSR=codec==='deltasigma'
    ?Math.max(1,Math.floor(inputSR/Math.max(1,Math.round(inputSR/targetSR))))
    :targetSR;
  return {channels:processed, sr:outSR};
}

